<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Aris">
<title>Aris</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:      #0a0a10;
    --bg2:     #12121a;
    --bg3:     #1a1a26;
    --bg4:     #222230;
    --text:    #e2e0f0;
    --dim:     #5a5870;
    --accent:  #a78bfa;
    --accent2: #7c5cbf;
    --success: #34d399;
    --warn:    #f59e0b;
    --danger:  #f87171;
    --border:  #2a2840;
    --glow:    rgba(167,139,250,0.15);
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Zen Kaku Gothic New’, sans-serif;
font-weight: 300;
height: 100dvh;
display: flex;
flex-direction: column;
overflow: hidden;
position: fixed;
width: 100%;
}

/* ── HEADER ── */
.header {
display: flex;
align-items: center;
gap: 12px;
padding: 14px 18px 12px;
background: var(–bg2);
border-bottom: 1px solid var(–border);
flex-shrink: 0;
position: relative;
}
.header::after {
content: ‘’;
position: absolute;
bottom: -1px; left: 0; right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(–accent), transparent);
opacity: 0.4;
}

.avatar {
width: 38px; height: 38px;
border-radius: 50%;
background: linear-gradient(135deg, var(–accent2), var(–accent));
display: flex; align-items: center; justify-content: center;
font-family: ‘DM Serif Display’, serif;
font-size: 18px;
color: #fff;
flex-shrink: 0;
box-shadow: 0 0 16px var(–glow);
position: relative;
}
.avatar::after {
content: ‘’;
position: absolute;
inset: -2px;
border-radius: 50%;
border: 1px solid var(–accent);
opacity: 0.4;
animation: pulse-ring 3s ease-in-out infinite;
}
@keyframes pulse-ring {
0%, 100% { transform: scale(1); opacity: 0.4; }
50% { transform: scale(1.08); opacity: 0.1; }
}

.header-info { flex: 1; min-width: 0; }
.header-name {
font-family: ‘DM Serif Display’, serif;
font-size: 17px;
color: var(–text);
letter-spacing: 0.04em;
}
.header-status {
font-size: 11px;
color: var(–dim);
letter-spacing: 0.06em;
display: flex;
align-items: center;
gap: 5px;
margin-top: 1px;
}
.status-dot {
width: 6px; height: 6px;
border-radius: 50%;
background: var(–success);
animation: blink 2.5s ease-in-out infinite;
}
@keyframes blink {
0%, 100% { opacity: 1; }
50% { opacity: 0.3; }
}

.emotion-badge {
font-size: 10px;
color: var(–accent);
background: rgba(167,139,250,0.1);
border: 1px solid rgba(167,139,250,0.2);
border-radius: 20px;
padding: 3px 9px;
letter-spacing: 0.05em;
transition: all 0.5s ease;
}

.header-btn {
background: none; border: none;
color: var(–dim);
padding: 6px;
cursor: pointer;
border-radius: 8px;
transition: color 0.2s;
font-size: 18px;
}
.header-btn:hover { color: var(–accent); }

/* ── MESSAGES ── */
.messages {
flex: 1;
overflow-y: auto;
padding: 16px 14px;
display: flex;
flex-direction: column;
gap: 14px;
scroll-behavior: smooth;
-webkit-overflow-scrolling: touch;
}
.messages::-webkit-scrollbar { width: 3px; }
.messages::-webkit-scrollbar-track { background: transparent; }
.messages::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

/* ── MESSAGE BUBBLE ── */
.msg { display: flex; gap: 8px; max-width: 100%; animation: fadein 0.3s ease; }
@keyframes fadein {
from { opacity: 0; transform: translateY(8px); }
to   { opacity: 1; transform: translateY(0); }
}

.msg.user { flex-direction: row-reverse; }

.msg-avatar {
width: 28px; height: 28px;
border-radius: 50%;
flex-shrink: 0;
display: flex; align-items: center; justify-content: center;
font-size: 13px;
margin-top: 2px;
}
.msg.aris .msg-avatar {
background: linear-gradient(135deg, var(–accent2), var(–accent));
color: #fff;
font-family: ‘DM Serif Display’, serif;
}
.msg.user .msg-avatar {
background: var(–bg4);
color: var(–dim);
}

.msg-body { max-width: calc(100% - 80px); display: flex; flex-direction: column; gap: 3px; }
.msg.user .msg-body { align-items: flex-end; }

.msg-name {
font-size: 10px;
color: var(–dim);
letter-spacing: 0.06em;
padding: 0 4px;
}

.msg-bubble {
padding: 10px 14px;
border-radius: 16px;
font-size: 14px;
line-height: 1.7;
word-break: break-word;
white-space: pre-wrap;
}
.msg.aris .msg-bubble {
background: var(–bg3);
border: 1px solid var(–border);
border-top-left-radius: 4px;
color: var(–text);
}
.msg.user .msg-bubble {
background: linear-gradient(135deg, var(–accent2), var(–accent));
border-bottom-right-radius: 4px;
color: #fff;
}

.msg-time {
font-size: 10px;
color: var(–dim);
padding: 0 4px;
}

/* ── TYPING INDICATOR ── */
.typing-indicator {
display: none;
align-items: center;
gap: 8px;
}
.typing-indicator.visible { display: flex; }
.typing-dots {
display: flex; gap: 4px;
padding: 10px 14px;
background: var(–bg3);
border: 1px solid var(–border);
border-radius: 16px;
border-top-left-radius: 4px;
}
.typing-dots span {
width: 6px; height: 6px;
border-radius: 50%;
background: var(–accent);
opacity: 0.4;
animation: dot-bounce 1.2s ease-in-out infinite;
}
.typing-dots span:nth-child(2) { animation-delay: 0.2s; }
.typing-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes dot-bounce {
0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
40% { transform: translateY(-5px); opacity: 1; }
}

/* ── EMOTION BAR ── */
.emotion-bar {
display: flex;
gap: 6px;
padding: 8px 14px;
background: var(–bg2);
border-top: 1px solid var(–border);
overflow-x: auto;
flex-shrink: 0;
-webkit-overflow-scrolling: touch;
}
.emotion-bar::-webkit-scrollbar { display: none; }

.emo-chip {
flex-shrink: 0;
font-size: 10px;
letter-spacing: 0.05em;
color: var(–dim);
background: var(–bg3);
border: 1px solid var(–border);
border-radius: 20px;
padding: 3px 10px;
display: flex; align-items: center; gap: 4px;
transition: all 0.5s ease;
}
.emo-chip.active {
color: var(–accent);
border-color: rgba(167,139,250,0.4);
background: rgba(167,139,250,0.08);
}
.emo-val {
font-size: 9px;
opacity: 0.7;
}

/* ── INPUT AREA ── */
.input-area {
padding: 10px 14px 14px;
background: var(–bg2);
border-top: 1px solid var(–border);
flex-shrink: 0;
padding-bottom: max(14px, env(safe-area-inset-bottom));
}
.input-row {
display: flex;
gap: 8px;
align-items: flex-end;
}
.input-wrap {
flex: 1;
background: var(–bg3);
border: 1px solid var(–border);
border-radius: 20px;
display: flex;
align-items: flex-end;
padding: 6px 14px;
transition: border-color 0.2s;
}
.input-wrap:focus-within {
border-color: rgba(167,139,250,0.5);
box-shadow: 0 0 0 3px rgba(167,139,250,0.06);
}
textarea {
flex: 1;
background: none;
border: none;
outline: none;
color: var(–text);
font-family: ‘Zen Kaku Gothic New’, sans-serif;
font-weight: 300;
font-size: 14px;
line-height: 1.5;
resize: none;
min-height: 22px;
max-height: 100px;
overflow-y: auto;
}
textarea::placeholder { color: var(–dim); }

.send-btn {
width: 42px; height: 42px;
border-radius: 50%;
background: linear-gradient(135deg, var(–accent2), var(–accent));
border: none;
color: #fff;
font-size: 16px;
cursor: pointer;
flex-shrink: 0;
display: flex; align-items: center; justify-content: center;
box-shadow: 0 2px 12px rgba(167,139,250,0.3);
transition: transform 0.15s, box-shadow 0.15s;
}
.send-btn:active { transform: scale(0.92); box-shadow: none; }
.send-btn:disabled { opacity: 0.4; pointer-events: none; }

/* ── API KEY SETUP ── */
.setup-overlay {
position: fixed; inset: 0;
background: rgba(10,10,16,0.97);
z-index: 100;
display: flex; align-items: center; justify-content: center;
padding: 24px;
animation: fadein 0.4s ease;
}
.setup-card {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 20px;
padding: 28px 24px;
width: 100%;
max-width: 380px;
}
.setup-icon {
font-family: ‘DM Serif Display’, serif;
font-size: 36px;
color: var(–accent);
text-align: center;
margin-bottom: 6px;
}
.setup-title {
font-family: ‘DM Serif Display’, serif;
font-size: 22px;
text-align: center;
margin-bottom: 4px;
}
.setup-sub {
font-size: 12px;
color: var(–dim);
text-align: center;
margin-bottom: 24px;
line-height: 1.6;
}
.setup-label {
font-size: 11px;
color: var(–dim);
letter-spacing: 0.08em;
margin-bottom: 8px;
}
.setup-input {
width: 100%;
background: var(–bg3);
border: 1px solid var(–border);
border-radius: 12px;
padding: 12px 16px;
color: var(–text);
font-family: ‘Zen Kaku Gothic New’, sans-serif;
font-size: 13px;
outline: none;
margin-bottom: 16px;
transition: border-color 0.2s;
}
.setup-input:focus { border-color: rgba(167,139,250,0.5); }
.setup-btn {
width: 100%;
background: linear-gradient(135deg, var(–accent2), var(–accent));
border: none;
border-radius: 12px;
padding: 14px;
color: #fff;
font-family: ‘Zen Kaku Gothic New’, sans-serif;
font-size: 14px;
font-weight: 500;
cursor: pointer;
letter-spacing: 0.06em;
transition: opacity 0.2s;
}
.setup-btn:active { opacity: 0.8; }
.setup-note {
font-size: 11px;
color: var(–dim);
text-align: center;
margin-top: 14px;
line-height: 1.6;
}

/* ── SETTINGS PANEL ── */
.settings-panel {
position: fixed; inset: 0;
background: var(–bg);
z-index: 50;
display: flex; flex-direction: column;
transform: translateX(100%);
transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.settings-panel.open { transform: translateX(0); }
.settings-header {
display: flex; align-items: center; gap: 12px;
padding: 16px 18px;
background: var(–bg2);
border-bottom: 1px solid var(–border);
}
.settings-back {
background: none; border: none;
color: var(–accent); font-size: 20px;
cursor: pointer; padding: 4px;
}
.settings-title {
font-family: ‘DM Serif Display’, serif;
font-size: 18px;
}
.settings-body {
flex: 1; overflow-y: auto;
padding: 20px 18px;
display: flex; flex-direction: column; gap: 20px;
}
.settings-section-title {
font-size: 11px;
color: var(–dim);
letter-spacing: 0.1em;
margin-bottom: 10px;
}
.settings-row {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 14px;
overflow: hidden;
}
.settings-item {
display: flex; align-items: center; justify-content: space-between;
padding: 14px 16px;
border-bottom: 1px solid var(–border);
gap: 12px;
}
.settings-item:last-child { border-bottom: none; }
.settings-item-label { font-size: 14px; }
.settings-item-sub { font-size: 11px; color: var(–dim); margin-top: 2px; }
.settings-item-val {
font-size: 13px; color: var(–accent);
text-align: right;
max-width: 140px;
overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.danger-btn {
width: 100%;
background: none;
border: 1px solid rgba(248,113,113,0.3);
border-radius: 12px;
padding: 14px;
color: var(–danger);
font-family: ‘Zen Kaku Gothic New’, sans-serif;
font-size: 14px;
cursor: pointer;
letter-spacing: 0.04em;
}
</style>

</head>
