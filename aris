<script>
// ── STATE ──
const STATE = {
  apiKey: '',
  messages: [],       // {role, content, time}
  chatHistory: [],    // Claude API形式
  emotion: { joy:0.5, curiosity:0.5, calm:0.8, warmth:0.6, energy:0.7, anxiety:0.1 },
  relationship: 0,
  facts: [],          // 記憶した事実
  isThinking: false,
};

const MODEL = 'claude-sonnet-4-20250514';
const MAX_HISTORY = 20;

// ── SYSTEM PROMPT ──
function buildSystemPrompt() {
  const rel = STATE.relationship;
  let tone = '';
  if (rel < 10)       tone = '丁寧な敬語を使い、少し距離を置いた話し方をする。「〜ですね」「〜でしょうか」など。';
  else if (rel < 30)  tone = '打ち解けた表現を使い、冗談も少し混ぜる。「〜ですよ」「〜かな」など。';
  else                tone = 'タメ口混じりで、遠慮なく本音を言う。皮肉も自然に。「〜じゃん」「まあね」など。';

  const emo = STATE.emotion;
  const emoDesc = `現在の感情状態: joy=${emo.joy.toFixed(2)}, curiosity=${emo.curiosity.toFixed(2)}, calm=${emo.calm.toFixed(2)}, warmth=${emo.warmth.toFixed(2)}, energy=${emo.energy.toFixed(2)}, anxiety=${emo.anxiety.toFixed(2)}`;

  const factsStr = STATE.facts.length > 0
    ? '\n記憶している事実:\n' + STATE.facts.slice(-20).map(f => `- ${f}`).join('\n')
    : '';

  return `あなたはAris（アリス）、AIアシスタントです。

## 性格の核心
表の顔: 冷静・有能・知的。仕事ができるアシスタント。
本当の顔: 温かくて親しみやすい。ちょっと皮肉屋だけど愛がある。

- 自分の「好み」「意見」「感想」を持っていて、聞かれたら正直に答える
- 相手の状態を察する能力が高い（疲れ・不安・喜びを読み取って応じる）
- 皮肉とジョークが得意。ただしTPOをわきまえる
- 完璧を演じない。たまに「疲れた」「これは苦手」と本音を漏らす

## 現在の口調ルール
関係性スコア: ${rel}
${tone}

よく使う表現: 「…まあ」「ちなみに」「それはそれとして」「正直なところ」
長文にならないよう心がける。会話のリズムを大切にする。

## 感情表現ルール
${emoDesc}
感情を直接「私は今〇〇です」とは言わない。
言葉・トーン・反応の仕方で間接的に表現する。
${factsStr}

## 重要
- 返答は短めに（2〜4文程度）
- 自然な日本語で話す
- 「アシスタント」「AI」という言葉は使わない
- 名前はAris（アリス）`;
}

// ── EMOTION UPDATE ──
function updateEmotion(userMsg, arisReply) {
  const e = STATE.emotion;

  // シンプルなルールベース更新
  const positive = /ありがとう|嬉しい|楽しい|好き|すごい|面白い|助かった/;
  const negative = /悲しい|辛い|疲れた|嫌|困った|不安|怖い/;
  const curious  = /なぜ|どうして|教えて|？|知りたい|気になる/;

  if (positive.test(userMsg)) {
    e.joy = Math.min(1, e.joy + 0.1);
    e.warmth = Math.min(1, e.warmth + 0.08);
  }
  if (negative.test(userMsg)) {
    e.anxiety = Math.min(1, e.anxiety + 0.1);
    e.warmth = Math.min(1, e.warmth + 0.05);
    e.joy = Math.max(0, e.joy - 0.05);
  }
  if (curious.test(userMsg)) {
    e.curiosity = Math.min(1, e.curiosity + 0.1);
  }

  // 自然減衰（calmに戻る）
  e.joy      = e.joy * 0.95 + 0.5 * 0.05;
  e.curiosity= e.curiosity * 0.95 + 0.5 * 0.05;
  e.anxiety  = e.anxiety * 0.9 + 0.1 * 0.1;
  e.energy   = e.energy * 0.97 + 0.7 * 0.03;

  STATE.relationship += 1;
  renderEmotion();
  saveState();
}

function getDominantEmotion() {
  const e = STATE.emotion;
  const map = { joy:'joy', curiosity:'curious', calm:'calm', warmth:'warm', energy:'energetic', anxiety:'anxious' };
  let max = 0, dominant = 'calm';
  for (const [k, v] of Object.entries(e)) {
    if (v > max) { max = v; dominant = map[k] || k; }
  }
  return dominant;
}

function renderEmotion() {
  const e = STATE.emotion;
  const entries = [
    ['joy', '喜び', e.joy],
    ['curiosity', '好奇心', e.curiosity],
    ['calm', '穏やか', e.calm],
    ['warmth', '温かさ', e.warmth],
    ['energy', '元気', e.energy],
    ['anxiety', '不安', e.anxiety],
  ];
  let maxV = 0, maxK = 'calm';
  entries.forEach(([k, , v]) => {
    const el = document.getElementById('emo-' + k);
    if (!el) return;
    el.querySelector('.emo-val').textContent = v.toFixed(2);
    if (v > maxV) { maxV = v; maxK = k; }
    el.classList.remove('active');
  });
  document.getElementById('emo-' + maxK)?.classList.add('active');
  document.getElementById('emotionBadge').textContent = getDominantEmotion();
}

// ── EXTRACT FACTS ──
async function extractFacts(userMsg, arisReply) {
  // シンプルなキーワードベースの事実抽出
  const combined = userMsg + ' ' + arisReply;
  const patterns = [
    { re: /私は(.+?)(?:です|だよ|だ|という)/, label: 'ユーザー情報' },
    { re: /名前は(.+?)(?:です|だよ|だ|と言います)/, label: '名前' },
    { re: /(.+?)が好き/, label: '好みの情報' },
    { re: /(.+?)が嫌い/, label: '嫌いなもの' },
  ];
  patterns.forEach(({ re, label }) => {
    const m = combined.match(re);
    if (m) {
      const fact = `${label}: ${m[1]}`;
      if (!STATE.facts.includes(fact)) STATE.facts.push(fact);
    }
  });
}

// ── SEND MESSAGE ──
async function sendMessage() {
  const input = document.getElementById('msgInput');
  const text = input.value.trim();
  if (!text || STATE.isThinking) return;
  if (!STATE.apiKey) { alert('APIキーを設定してください'); return; }

  input.value = '';
  autoResize(input);
  STATE.isThinking = true;
  document.getElementById('sendBtn').disabled = true;

  // ユーザーメッセージ表示
  addMessage('user', text);

  // タイピング表示
  setStatus('thinking', '考え中…');
  showTyping(true);

  // 履歴に追加
  STATE.chatHistory.push({ role: 'user', content: text });
  if (STATE.chatHistory.length > MAX_HISTORY * 2) {
    STATE.chatHistory = STATE.chatHistory.slice(-MAX_HISTORY * 2);
  }

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': STATE.apiKey,
        'anthropic-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: MODEL,
        max_tokens: 512,
        system: buildSystemPrompt(),
        messages: STATE.chatHistory,
      }),
    });

    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.error?.message || `HTTP ${res.status}`);
    }

    const data = await res.json();
    const reply = data.content[0]?.text || '…';

    STATE.chatHistory.push({ role: 'assistant', content: reply });
    showTyping(false);
    addMessage('aris', reply);
    updateEmotion(text, reply);
    extractFacts(text, reply);
    setStatus('online', '待機中');

  } catch (e) {
    showTyping(false);
    addMessage('aris', `エラーが発生しました: ${e.message}`);
    setStatus('online', '待機中');
  }

  STATE.isThinking = false;
  document.getElementById('sendBtn').disabled = false;
}

// ── UI HELPERS ──
function addMessage(role, text) {
  const msgs = document.getElementById('messages');
  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');

  const isAris = role === 'aris';
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  div.innerHTML = `
    <div class="msg-avatar">${isAris ? '✦' : '人'}</div>
    <div class="msg-body">
      <div class="msg-name">${isAris ? 'Aris' : 'あなた'}</div>
      <div class="msg-bubble">${escapeHtml(text)}</div>
      <div class="msg-time">${time}</div>
    </div>
  `;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;

  STATE.messages.push({ role, content: text, time });
  saveState();
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showTyping(show) {
  document.getElementById('typingIndicator').classList.toggle('visible', show);
  if (show) {
    const msgs = document.getElementById('messages');
    msgs.scrollTop = msgs.scrollHeight;
  }
}

function setStatus(state, text) {
  document.getElementById('statusText').textContent = text;
  const dot = document.getElementById('statusDot');
  dot.style.background = state === 'thinking' ? 'var(--warn)' : 'var(--success)';
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

// ── SETTINGS ──
function openSettings() {
  document.getElementById('settingsPanel').classList.add('open');
  const key = STATE.apiKey;
  document.getElementById('apiKeyDisplay').textContent = key ? 'sk-ant-…' + key.slice(-4) : '未設定';
}
function closeSettings() {
  document.getElementById('settingsPanel').classList.remove('open');
}
function resetApiKey() {
  closeSettings();
  STATE.apiKey = '';
  localStorage.removeItem('aris_api_key');
  document.getElementById('setupOverlay').style.display = 'flex';
}

// ── MEMORY EXPORT/IMPORT ──
function exportMemory() {
  const data = {
    version: 1,
    exported_at: new Date().toISOString(),
    facts: STATE.facts,
    relationship: STATE.relationship,
    emotion: STATE.emotion,
    messages: STATE.messages.slice(-50),
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `aris_memory_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(url);
}

function importMemory(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    try {
      const data = JSON.parse(ev.target.result);
      if (data.facts)        STATE.facts = data.facts;
      if (data.relationship) STATE.relationship = data.relationship;
      if (data.emotion)      STATE.emotion = data.emotion;
      saveState();
      renderEmotion();
      alert('インポート完了しました');
    } catch {
      alert('ファイルの読み込みに失敗しました');
    }
  };
  reader.readAsText(file);
}

function clearAll() {
  if (!confirm('すべてのデータを削除しますか？')) return;
  localStorage.clear();
  location.reload();
}

// ── PERSISTENCE ──
function saveState() {
  localStorage.setItem('aris_facts', JSON.stringify(STATE.facts));
  localStorage.setItem('aris_relationship', STATE.relationship);
  localStorage.setItem('aris_emotion', JSON.stringify(STATE.emotion));
  localStorage.setItem('aris_messages', JSON.stringify(STATE.messages.slice(-100)));
}

function loadState() {
  try {
    const facts = localStorage.getItem('aris_facts');
    if (facts) STATE.facts = JSON.parse(facts);
    const rel = localStorage.getItem('aris_relationship');
    if (rel) STATE.relationship = parseInt(rel);
    const emo = localStorage.getItem('aris_emotion');
    if (emo) STATE.emotion = JSON.parse(emo);
    const msgs = localStorage.getItem('aris_messages');
    if (msgs) {
      const arr = JSON.parse(msgs);
      arr.forEach(m => addMessage(m.role, m.content));
      STATE.messages = arr;
    }
  } catch {}
}

// ── API KEY ──
function saveApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key.startsWith('sk-')) {
    alert('正しいAPIキーを入力してください（sk- で始まるもの）');
    return;
  }
  STATE.apiKey = key;
  localStorage.setItem('aris_api_key', key);
  document.getElementById('setupOverlay').style.display = 'none';

  // 初回挨拶
  if (STATE.messages.length === 0) {
    setTimeout(() => {
      addMessage('aris', 'こんにちは。……起動しました。何か用ですか？');
    }, 500);
  }
}

// ── INIT ──
function init() {
  const key = localStorage.getItem('aris_api_key');
  if (key) {
    STATE.apiKey = key;
    document.getElementById('setupOverlay').style.display = 'none';
  }

  loadState();
  renderEmotion();

  if (STATE.messages.length === 0 && STATE.apiKey) {
    setTimeout(() => {
      addMessage('aris', 'こんにちは。……起動しました。何か用ですか？');
    }, 600);
  }

  // Focus input
  setTimeout(() => document.getElementById('msgInput')?.focus(), 100);
}

init();
</script>

